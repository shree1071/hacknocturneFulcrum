# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

GOOGLE_API_KEY=your_google_api_key_here
INSFORGE_BASE_URL=https://your-project.insforge.app
INSFORGE_SERVICE_KEY=your_insforge_service_or_anon_key_here
TAVUS_API_KEY=your_tavus_api_key_here
TAVUS_REPLICA_ID=your_tavus_replica_id_here

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# Pinata IPFS
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# Database Encryption Vault Master Key
# Generate via Python: import secrets; secrets.token_hex(32)
VAULT_MASTER_KEY=your_32_byte_hex_key_here

# Database Encryption Vault Master Key
# Generate via Python: import secrets; secrets.token_hex(32)
VAULT_MASTER_KEY=your_32_byte_hex_key_here
